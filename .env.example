PORT=5001
NODE_ENV=development

# Local MongoDB (default)
MONGODB_URI=mongodb://127.0.0.1:27017/cakezake-orders

# MongoDB Atlas (production) — uncomment and replace when deploying
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/cakezake-orders

SESSION_SECRET=your_random_secret_here
SESSION_MAX_AGE=28800000

# Generate with: node -e "const b=require('bcrypt');b.hash('200312',10).then(console.log)"
ADMIN_PIN_HASH=$2b$10$examplehashhere

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1234567890

OWNER_PHONE=+977984XXXXXXX

CLIENT_URL=http://localhost:5173
SERVER_URL=https://orders.cakezake.com

# Meta (Facebook, Instagram, WhatsApp Business Cloud API)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_WEBHOOK_VERIFY_TOKEN=your_random_webhook_verify_token

# TikTok (for comment management)
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
